build src/sixlowpan/examples/CMakeFiles/install/strip.util: CUSTOM_COMMAND src/sixlowpan/examples/all
  COMMAND = cd /mnt/d/Project/ns-3-ub/build-wsl/src/sixlowpan/examples && /usr/bin/cmake -DCMAKE_INSTALL_DO_STRIP=1 -P cmake_install.cmake
  DESC = Installing the project stripped...
  pool = console
  restat = 1

