# =============================================================================
# Object build statements for EXECUTABLE target perf-io


#############################################
# Order-only phony target for perf-io

build cmake_object_order_depends_target_perf-io: phony || cmake_object_order_depends_target_core

build utils/CMakeFiles/perf-io.dir/perf/perf-io.cc.o: CXX_COMPILER__perf-io_unscanned_Release /mnt/d/Project/ns-3-ub/utils/perf/perf-io.cc || cmake_object_order_depends_target_perf-io
  DEFINES = -DEIGEN_MPL2_ONLY -DHAVE_BOOST -DHAVE_BOOST_UNITS -DHAVE_EIGEN3 -DHAVE_GSL -DHAVE_LIBXML2 -DHAVE_SQLITE3 -DNS3_BUILD_PROFILE_RELEASE -DPROJECT_SOURCE_PATH=\"/mnt/d/Project/ns-3-ub\" -D__LINUX__
  DEP_FILE = utils/CMakeFiles/perf-io.dir/perf/perf-io.cc.o.d
  FLAGS = -O3 -DNDEBUG -std=c++20 -fPIE   -fno-semantic-interposition -Wall -Wpedantic
  INCLUDES = -I/mnt/d/Project/ns-3-ub/build/include -I/usr -I/usr/include/eigen3 -I/usr/include/freetype2 -I/usr/include/glib-2.0 -I/usr/lib/x86_64-linux-gnu/glib-2.0/include -I/usr/include/gdk-pixbuf-2.0 -I/usr/include/gtk-3.0 -I/usr/include/cairo -I/usr/include/pango-1.0 -I/usr/include/harfbuzz -I/usr/include/atk-1.0 -I/usr/include/libxml2
  LAUNCHER = /usr/bin/ccache 
  OBJECT_DIR = utils/CMakeFiles/perf-io.dir
  OBJECT_FILE_DIR = utils/CMakeFiles/perf-io.dir/perf


# =============================================================================
# Link build statements for EXECUTABLE target perf-io


#############################################
# Link the executable /mnt/d/Project/ns-3-ub/build/utils/perf/ns3.44-perf-io

build /mnt/d/Project/ns-3-ub/build/utils/perf/ns3.44-perf-io: CXX_EXECUTABLE_LINKER__perf-io_Release utils/CMakeFiles/perf-io.dir/perf/perf-io.cc.o | /usr/lib/x86_64-linux-gnu/libgsl.so /usr/lib/x86_64-linux-gnu/libgslcblas.so || /mnt/d/Project/ns-3-ub/build/lib/libns3.44-core.so /mnt/d/Project/ns-3-ub/build/lib/libns3.44-core.so
  FLAGS = -O3 -DNDEBUG
  LINK_LIBRARIES = -Wl,-rpath,/mnt/d/Project/ns-3-ub/build/lib  -Wl,--no-as-needed  /mnt/d/Project/ns-3-ub/build/lib/libns3.44-core.so  -Wl,--as-needed  -Wl,--no-as-needed  /usr/lib/x86_64-linux-gnu/libgsl.so  /usr/lib/x86_64-linux-gnu/libgslcblas.so
  LINK_PATH = -L/mnt/d/Project/ns-3-ub/build/lib
  OBJECT_DIR = utils/CMakeFiles/perf-io.dir
  POST_BUILD = :
  PRE_LINK = :
  TARGET_FILE = /mnt/d/Project/ns-3-ub/build/utils/perf/ns3.44-perf-io
  TARGET_PDB = ns3.44-perf-io.dbg


#############################################
# Utility command for edit_cache

build utils/CMakeFiles/edit_cache.util: CUSTOM_COMMAND
  COMMAND = cd /mnt/d/Project/ns-3-ub/build-wsl/utils && /usr/bin/cmake -E echo No\ interactive\ CMake\ dialog\ available.
  DESC = No interactive CMake dialog available...
  restat = 1

build utils/edit_cache: phony utils/CMakeFiles/edit_cache.util


#############################################
# Utility command for rebuild_cache

build utils/CMakeFiles/rebuild_cache.util: CUSTOM_COMMAND
  COMMAND = cd /mnt/d/Project/ns-3-ub/build-wsl/utils && /usr/bin/cmake --regenerate-during-build -S/mnt/d/Project/ns-3-ub -B/mnt/d/Project/ns-3-ub/build-wsl
  DESC = Running CMake to regenerate build system...
  pool = console
  restat = 1

build utils/rebuild_cache: phony utils/CMakeFiles/rebuild_cache.util


#############################################
# Utility command for list_install_components

build utils/list_install_components: phony


#############################################
# Utility command for install

build utils/CMakeFiles/install.util: CUSTOM_COMMAND utils/all
  COMMAND = cd /mnt/d/Project/ns-3-ub/build-wsl/utils && /usr/bin/cmake -P cmake_install.cmake
  DESC = Install the project...
  pool = console
  restat = 1

build utils/install: phony utils/CMakeFiles/install.util


#############################################
# Utility command for install/local

build utils/CMakeFiles/install/local.util: CUSTOM_COMMAND utils/all
  COMMAND = cd /mnt/d/Project/ns-3-ub/build-wsl/utils && /usr/bin/cmake -DCMAKE_INSTALL_LOCAL_ONLY=1 -P cmake_install.cmake
  DESC = Installing only the local directory...
  pool = console
  restat = 1

build utils/install/local: phony utils/CMakeFiles/install/local.util


#############################################
# Utility command for install/strip

build utils/CMakeFiles/install/strip.util: CUSTOM_COMMAND utils/all
  COMMAND = cd /mnt/d/Project/ns-3-ub/build-wsl/utils && /usr/bin/cmake -DCMAKE_INSTALL_DO_STRIP=1 -P cmake_install.cmake
  DESC = Installing the project stripped...
  pool = console
  restat = 1

build utils/install/strip: phony utils/CMakeFiles/install/strip.util

